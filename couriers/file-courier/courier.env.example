# Copy to courier.env (gitignored) and fill in. The wrapper auto-loads it.
# Slack bot token (xoxb-…). Resolution order:
#   OCEAN_SLACK_BOT_TOKEN > SLACK_BOT_TOKEN > token file ($OCEAN_SLACK_TOKEN_FILE, default ~/.slack_token)
OCEAN_SLACK_BOT_TOKEN=

# Optional: point at a token file instead of inlining the secret.
# OCEAN_SLACK_TOKEN_FILE=~/.slack_token
