# content-agent — environment template (spec §9, §12).
# Copy to content-agent.env (gitignored) and fill in. NEVER commit the real file.

# --- content-posting-lab API (primary pipeline path, spec §6.1) ------------
# The deployed FastAPI backend content-agent calls for generate/gallery/status.
CONTENT_LAB_API_URL=https://content-lab.example.com
CONTENT_LAB_API_KEY=

# --- Ocean daemon (the brain) ----------------------------------------------
# Where the bridge POSTs /v1/prompt. Default matches the daemon's bind.
OCEAN_DAEMON_URL=http://127.0.0.1:4780
