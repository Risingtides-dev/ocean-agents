#!/usr/bin/env bash
# Thin CLI wrapper for the Bonzai harness — the worktree gardener.
# Usage:
#   bin/bonzai scan  <repo>...
#   bin/bonzai board <repo>... [--out path.html]
#   bin/bonzai prune <repo>... [--noise] [--apply]
#   bin/bonzai apply --decisions decisions.json
set -euo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
exec python3 "$HERE/harness/bonzai.py" "$@"
