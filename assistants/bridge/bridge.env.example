# Slack inbound bridge — environment template (spec §5, §12).
# Copy to bridge.env (gitignored) and fill in. NEVER commit the real file.
# One Slack app per agent identity (spec §5) → each agent gets its own tokens.

# --- Slack app (content-agent identity) ------------------------------------
# Socket Mode app-level token (xapp-...) — opens the inbound WebSocket.
SLACK_APP_TOKEN=
# Bot user OAuth token (xoxb-...) — outbound via couriers/transport/slack.py.
SLACK_BOT_TOKEN=

# Bot scopes required (set on the Slack app, not here):
#   chat:write, files:write, channels:read, canvases:write,
#   app_mentions:read, im:history, im:read
#
# Event subscriptions to enable (delivered over Socket Mode, no public URL):
#   app_mention   (mentions in channels/threads)
#   message.im    (direct messages)
# Full setup walkthrough: assistants/bridge/RUN.md

# --- Ocean daemon (the brain) ----------------------------------------------
OCEAN_DAEMON_URL=http://127.0.0.1:4780

# Optional tuning (sane defaults if unset). Daemon timeout/retries are reused
# from OCEAN-84's hardened router invocation; log level → listener verbosity.
# OCEAN_DAEMON_TIMEOUT=300
# OCEAN_DAEMON_MAX_TRIES=3
# OCEAN_LOG_LEVEL=INFO
